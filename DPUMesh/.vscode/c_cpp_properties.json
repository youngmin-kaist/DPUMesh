{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "/opt/mellanox/doca/include/**",
                "/opt/mellanox/doca/lib/**"
            ],
            "defines": [
                "__dpa_rpc__=",
                "__dpa_global__="
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-arm64",
            "configurationProvider": "mesonbuild.mesonbuild"
        }
    ],
    "version": 4
}